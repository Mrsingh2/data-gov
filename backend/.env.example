# PostgreSQL connection string (Neon, Supabase, Railway, or local)
DATABASE_URL="postgresql://user:password@host:5432/datagov?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# File upload
# For local dev, files stored in /tmp/data-gov-uploads
# For production, set BLOB_READ_WRITE_TOKEN from Vercel Blob
BLOB_READ_WRITE_TOKEN=""
UPLOAD_DIR="/tmp/data-gov-uploads"

# CORS - set to your frontend URL
FRONTEND_URL="http://localhost:3000"

# Anonymization
ANONYMIZE_SALT="change-this-unique-salt-string"

# Environment
NODE_ENV="development"
PORT=3001
